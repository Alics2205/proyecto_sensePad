  <a class="header-logo" href="inicio.jsp">
    <img src="data:image/png;base64," alt="SensePad">
    <h2>SensePad</h2>
  </a>

  <div class="header-controls">
    <button class="notif-btn" aria-label="Notificaciones">
      <svg class="ico" viewBox="0 0 24 24"><path d="M18 8a6 6 0 00-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
    </button>
    <div class="user-profile">
      <div class="user-avatar" aria-hidden="true">JP</div>
