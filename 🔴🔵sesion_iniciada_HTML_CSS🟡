<!-- ─── LAYOUT ─── -->
<div class="layout">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <nav aria-label="Menú principal">
      <ul class="sidebar-nav">
        <li>
          <a href="inicio.jsp" class="active" aria-current="page">
            <svg class="ico" viewBox="0 0 24 24"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H5a1 1 0 01-1-1V9.5z"/><path d="M9 21V12h6v9"/></svg>
            Inicio
          </a>
        </li>
        <li>
          <a href="mapa.jsp">
            <svg class="ico" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            Mapa
          </a>
        </li>
        <li>
          <a href="estado.jsp">
            <svg class="ico" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            Estado
          </a>
        </li>
        <li>
          <a href="alarmas.jsp">
            <svg class="ico" viewBox="0 0 24 24"><path d="M18 8a6 6 0 00-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
            Alarmas
          </a>
        </li>
        <li>
          <a href="cerrarSesion.jsp" class="logout">
            <svg class="ico" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Cerrar sesión
          </a>
        </li>
      </ul>
    </nav>

    <div class="device-card">
      <div class="device-card-header">
        <div class="device-icon">
          <svg viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
        </div>
        <div>
          <p class="device-label">Dispositivo</p>
          <p class="device-id">SP-001</p>
        </div>
      </div>
      <span class="badge-online">Conectado</span>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="main-content">

    <!-- page header -->
    <div class="page-header">
      <div>
        <h1>Bienvenido a <em>SensePad</em></h1>
        <p>Visualización rápida del estado y ubicación del usuario.</p>
      </div>
      <div>
        <button class="refresh-btn">
          <svg viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
          Actualizar ubicación
        </button>
        <p class="refresh-sub">Última actualización: hace 12 seg</p>
      </div>
    </div>

    <!-- top grid: map + status -->
    <section class="top-grid" aria-label="Mapa y estado del dispositivo">

      <!-- map card -->
      <article class="card">
        <header class="card-header">
          <h2 class="card-title">
            <svg class="ico" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            Ubicación aproximada
          </h2>
        </header>

        <div class="map-embed">
          <iframe src="https://maps.google.com/maps?q=caballito+buenos+aires&t=&z=15&ie=UTF8&iwloc=&output=embed" title="Mapa de ubicación"></iframe>
        </div>

        <div class="location-meta">
          <div class="location-detail">
            <p class="loc-label">Zona actual</p>
            <p class="loc-val">Caballito, CABA</p>
            <p class="loc-sub">Actualizado hace 12 segundos</p>
          </div>
          <div class="map-actions">
            <button class="btn btn-outline">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93l-1.41 1.41M4.93 4.93l1.41 1.41M4.93 19.07l1.41-1.41M19.07 19.07l-1.41-1.41M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>
              Localizar
            </button>
            <a href="mapa.jsp" class="btn btn-primary">
              <svg viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              Ver en mapa
            </a>
          </div>
        </div>
      </article>

      <!-- status card -->
      <article class="card">
        <header class="card-header">
          <h2 class="card-title">
            <svg class="ico" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            Estado del dispositivo
          </h2>
        </header>

        <ul class="status-list">
          <li class="status-row">
            <div class="status-icon si-green">
              <svg viewBox="0 0 24 24"><rect x="2" y="7" width="18" height="11" rx="2"/><path d="M22 11v3"/></svg>
            </div>
            <div class="status-info">
              <p class="status-label">Batería</p>
              <p class="status-val">87%</p>
              <div class="prog"><div class="prog-fill" style="width:87%"></div></div>
            </div>
            <span class="dot-ok">Cargando</span>
          </li>
          <li class="status-row">
            <div class="status-icon si-blue">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 3a4.5 4.5 0 010 18A4.5 4.5 0 0112 3z"/><line x1="3.6" y1="9" x2="20.4" y2="9"/><line x1="3.6" y1="15" x2="20.4" y2="15"/></svg>
            </div>
            <div class="status-info">
              <p class="status-label">Señal GPS</p>
              <p class="status-val">Excelente</p>
              <span class="dot-ok">Activo</span>
            </div>
          </li>
          <li class="status-row">
            <div class="status-icon si-teal">
              <svg viewBox="0 0 24 24"><path d="M5 12.55a11 11 0 0114.08 0"/><path d="M1.42 9a16 16 0 0121.16 0"/><path d="M8.53 16.11a6 6 0 016.95 0"/><circle cx="12" cy="20" r="1" fill="currentColor"/></svg>
            </div>
            <div class="status-info">
              <p class="status-label">Internet</p>
              <p class="status-val">Conectado</p>
              <span class="dot-ok">Estable</span>
            </div>
          </li>
          <li class="status-row">
            <div class="status-icon si-green">
              <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div class="status-info">
              <p class="status-label">Estado general</p>
              <p class="status-val" style="color:var(--green)">Funcionando correctamente</p>
            </div>
          </li>
        </ul>
      </article>

    </section>

    <!-- bottom grid: alarms + quick access -->
    <section class="bottom-grid" aria-label="Alarmas y acceso rápido">

      <!-- alarms card -->
      <article class="card">
        <header class="card-header">
          <h2 class="card-title">
            <svg class="ico" viewBox="0 0 24 24"><path d="M18 8a6 6 0 00-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
            Últimas alarmas
          </h2>
          <a href="alarmas.jsp" class="card-link">Ver todas</a>
        </header>

        <ul class="alarm-list">
          <li class="alarm-row alarm-red">
            <div class="alarm-icon alarm-red">
              <svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <div>
              <p class="alarm-name">SOS activado</p>
              <p class="alarm-time">Hoy, 14:35</p>
            </div>
            <span class="alarm-arrow"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></span>
          </li>
          <li class="alarm-row alarm-orange">
            <div class="alarm-icon alarm-orange">
              <svg viewBox="0 0 24 24"><rect x="2" y="7" width="14" height="11" rx="2"/><path d="M16 11v3"/><line x1="7" y1="12" x2="10" y2="12"/></svg>
            </div>
            <div>
              <p class="alarm-name">Batería baja</p>
              <p class="alarm-time">Hoy, 12:10</p>
            </div>
            <span class="alarm-arrow"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></span>
          </li>
          <li class="alarm-row alarm-gray">
            <div class="alarm-icon alarm-gray">
              <svg viewBox="0 0 24 24"><path d="M18.36 6.64a9 9 0 11-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>
            </div>
            <div>
              <p class="alarm-name">Dispositivo conectado</p>
              <p class="alarm-time">Hoy, 09:25</p>
            </div>
            <span class="alarm-arrow"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></span>
          </li>
        </ul>

        <button class="see-all-btn">Ver todas las alarmas</button>
      </article>

      <!-- quick access card -->
      <article class="card">
        <header class="card-header">
          <h2 class="card-title">
            <svg class="ico" viewBox="0 0 24 24"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>
            Acceso rápido
          </h2>
        </header>

        <p class="quick-desc">
          Desde aquí podés acceder rápidamente al mapa completo para visualizar la ubicación exacta del usuario y el recorrido realizado.
        </p>

        <a href="mapa.jsp" class="map-cta">
          <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
          Abrir mapa completo
        </a>
      </article>

    </section>

  </main>
</div>

</body>
</html>
