<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SensePad — Panel Principal</title>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
*, *::before, *::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --bg:         #F8F4F0;
  --navy:       #1E3048;
  --navy-2:     #253d58;
  --coral:      #C4715A;
  --coral-d:    #B5624C;
  --coral-l:    rgba(196,113,90,.1);
  --border:     #E4D8CE;
  --green:      #2DBE60;
  --green-bg:   #E8F8EE;
  --green-text: #2e7d5a;
  --white:      #FFFFFF;
  --text:       #1A1F2E;
  --mid:        #4A4540;
  --muted:      #9A8C84;
  --red:        #D9503E;
  --red-bg:     #FDF2F0;
  --orange:     #E07A30;
  --orange-bg:  #FFF4EA;
  --gray-bg:    #F3F3F3;
  --blue:       #4A78D4;
  --blue-bg:    #EDF2FB;
  --teal:       #2AA9A9;
  --teal-bg:    #E8F6F6;

  --radius-sm:  9px;
  --radius-md:  14px;
  --radius-lg:  20px;
  --radius-xl:  26px;

  --shadow-sm:  0 2px 8px rgba(0,0,0,.05);
  --shadow-md:  0 4px 16px rgba(0,0,0,.07);
  --shadow-lg:  0 16px 40px rgba(0,0,0,.1);
}

/* ─────────────────────────────────────────────
   BASE
───────────────────────────────────────────── */
body {
  background: var(--bg);
  font-family: 'Manrope', sans-serif;
  color: var(--text);
  line-height: 1.5;
}

/* shared icon style */
.ico     { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.65; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
.ico-sm  { width: 15px; height: 15px; stroke: currentColor; fill: none; stroke-width: 1.65; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
.ico-lg  { width: 22px; height: 22px; stroke: currentColor; fill: none; stroke-width: 1.65; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }

/* ─────────────────────────────────────────────
   HEADER
───────────────────────────────────────────── */
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  height: 66px;
  background: var(--navy);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28px;
  box-shadow: 0 2px 16px rgba(0,0,0,.15);
}

.site-header::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--coral), transparent);
  opacity: .5;
}

/* logo */
.header-logo {
  display: flex;
  align-items: center;
  gap: 11px;
  text-decoration: none;
}

.header-logo img {
  height: 44px;
  border-radius: 10px;
  background: rgba(255,255,255,.07);
  padding: 3px;
}

.header-logo h2 {
  font-family: 'DM Serif Display', serif;
  font-weight: 400;
  font-size: 1.2rem;
  color: #fff;
  letter-spacing: .2px;
}

/* user controls */
.header-controls {
  display: flex;
  align-items: center;
  gap: 10px;
}

.notif-btn {
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
  border-radius: var(--radius-sm);
  border: 1px solid rgba(255,255,255,.12);
  color: rgba(255,255,255,.55);
  cursor: pointer;
  transition: all .2s;
}

.notif-btn:hover {
  background: rgba(255,255,255,.1);
  color: #fff;
}

.user-profile {
  display: flex;
  align-items: center;
  gap: 9px;
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.1);
  padding: 6px 12px 6px 7px;
  border-radius: 10px;
  cursor: pointer;
  transition: all .2s;
}

.user-profile:hover { background: rgba(255,255,255,.12); }

.user-avatar {
  width: 32px; height: 32px;
  border-radius: 50%;
  background: var(--coral);
  display: flex; align-items: center; justify-content: center;
  font-size: .8rem; font-weight: 700; color: #fff;
}

.user-profile span {
  font-size: .85rem;
  font-weight: 600;
  color: rgba(255,255,255,.8);
}

/* ─────────────────────────────────────────────
   LAYOUT WRAPPER
───────────────────────────────────────────── */
.layout {
  display: flex;
  height: calc(100vh - 66px);
}

/* ─────────────────────────────────────────────
   SIDEBAR
───────────────────────────────────────────── */
.sidebar {
  width: 240px;
  flex-shrink: 0;
  background: var(--white);
  border-right: 1px solid var(--border);
  padding: 20px 16px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 4px;
  list-style: none;
}

.sidebar-nav a {
  display: flex;
  align-items: center;
  gap: 11px;
  padding: 11px 13px;
  border-radius: 11px;
  text-decoration: none;
  font-size: .88rem;
  font-weight: 600;
  color: var(--mid);
  transition: all .2s;
  position: relative;
}

.sidebar-nav a:hover { background: #FDF4EF; color: var(--coral); }

.sidebar-nav a.active { background: var(--coral-l); color: var(--coral); }

.sidebar-nav a.active::before {
  content: '';
  position: absolute;
  left: 0; top: 20%; height: 60%;
  width: 3px;
  background: var(--coral);
  border-radius: 0 3px 3px 0;
}

.sidebar-nav a.logout { color: var(--muted); }
.sidebar-nav a.logout:hover { background: var(--red-bg); color: var(--red); }

/* device card */
.device-card {
  border: 1px solid var(--border);
  padding: 16px;
  border-radius: 16px;
  background: #FFF8F5;
}

.device-card-header {
  display: flex;
  align-items: center;
  gap: 9px;
  margin-bottom: 10px;
}

.device-icon {
  width: 38px; height: 38px;
  background: var(--navy);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.device-icon svg {
  width: 18px; height: 18px;
  stroke: rgba(255,255,255,.7);
  fill: none;
  stroke-width: 1.6;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.device-label {
  font-size: .8rem;
  color: var(--muted);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.device-id {
  font-size: .9rem;
  font-weight: 700;
  color: var(--text);
}

.badge-online {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: var(--green);
  font-weight: 700;
  font-size: .82rem;
}

.badge-online::before {
  content: '';
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--green);
  animation: pulse-dot 2s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; }
  50%       { opacity: .3; }
}

/* ─────────────────────────────────────────────
   MAIN CONTENT
───────────────────────────────────────────── */
.main-content {
  flex: 1;
  padding: 26px 28px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* page header row */
.page-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.page-header h1 {
  font-family: 'DM Serif Display', serif;
  font-weight: 400;
  font-size: 1.9rem;
  line-height: 1.2;
}

.page-header h1 em { font-style: italic; color: var(--coral); }
.page-header p { font-size: .88rem; color: var(--muted); margin-top: 4px; }

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 7px;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 9px 15px;
  font-size: .82rem;
  font-weight: 600;
  color: var(--mid);
  cursor: pointer;
  font-family: 'Manrope', sans-serif;
  transition: all .2s;
}

.refresh-btn svg {
  width: 14px; height: 14px;
  stroke: currentColor; fill: none;
  stroke-width: 2;
  stroke-linecap: round; stroke-linejoin: round;
}

.refresh-btn:hover { background: var(--bg); border-color: #c8bfb8; }

.refresh-sub {
  font-size: .75rem;
  color: var(--muted);
  margin-top: 4px;
  text-align: right;
}

/* ─────────────────────────────────────────────
   CARDS
───────────────────────────────────────────── */
.card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 22px;
  box-shadow: var(--shadow-md);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.card-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 1rem;
  font-weight: 700;
  color: var(--text);
}

.card-title svg { stroke: var(--coral); }

.card-link {
  font-size: .78rem;
  font-weight: 700;
  color: var(--coral);
  text-decoration: none;
}

.card-link:hover { opacity: .75; }

/* ─────────────────────────────────────────────
   TOP GRID (map + status)
───────────────────────────────────────────── */
.top-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 20px;
}

/* map */
.map-embed {
  height: 280px;
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1px solid var(--border);
  margin-bottom: 16px;
}

.map-embed iframe {
  width: 100%; height: 100%;
  border: none;
  display: block;
}

.location-meta {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.location-detail .loc-label {
  font-size: .75rem;
  color: var(--muted);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .8px;
}

.location-detail .loc-val { font-size: .9rem; font-weight: 700; margin-top: 2px; }
.location-detail .loc-sub { font-size: .78rem; color: var(--muted); margin-top: 1px; }

.map-actions {
  display: flex;
  gap: 8px;
}

/* buttons */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 9px 14px;
  border-radius: var(--radius-sm);
  border: none;
  font-size: .82rem;
  font-weight: 700;
  font-family: 'Manrope', sans-serif;
  cursor: pointer;
  transition: all .2s;
  text-decoration: none;
}

.btn svg {
  width: 14px; height: 14px;
  stroke: currentColor; fill: none;
  stroke-width: 1.9;
  stroke-linecap: round; stroke-linejoin: round;
}

.btn:hover { transform: translateY(-1px); }

.btn-outline  { background: var(--bg); color: var(--mid); border: 1px solid var(--border); }
.btn-outline:hover  { background: #f0e8e0; }

.btn-primary  { background: var(--coral); color: #fff; box-shadow: 0 4px 12px rgba(196,113,90,.25); }
.btn-primary:hover  { background: var(--coral-d); }

/* status rows */
.status-list {
  list-style: none;
  display: flex;
  flex-direction: column;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
}

.status-row:last-child { border-bottom: none; }

.status-icon {
  width: 40px; height: 40px;
  border-radius: 11px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.status-icon svg {
  width: 20px; height: 20px;
  stroke: currentColor; fill: none;
  stroke-width: 1.6;
  stroke-linecap: round; stroke-linejoin: round;
}

.si-green  { background: var(--green-bg); color: var(--green); }
.si-blue   { background: var(--blue-bg);  color: var(--blue); }
.si-teal   { background: var(--teal-bg);  color: var(--teal); }

.status-info { flex: 1; }
.status-label { font-size: .8rem; color: var(--muted); font-weight: 600; }
.status-val   { font-size: .95rem; font-weight: 700; margin-top: 1px; }

.dot-ok {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: .78rem;
  color: var(--green);
  font-weight: 700;
  margin-top: 2px;
}

.dot-ok::before {
  content: '';
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--green);
}

.prog {
  height: 5px;
  background: var(--border);
  border-radius: 10px;
  overflow: hidden;
  margin-top: 5px;
}

.prog-fill { height: 100%; background: var(--green); border-radius: 10px; }

/* ─────────────────────────────────────────────
   BOTTOM GRID (alarms + quick access)
───────────────────────────────────────────── */
.bottom-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

/* alarm rows */
.alarm-list { list-style: none; }

.alarm-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  border-radius: 12px;
  margin-bottom: 8px;
  cursor: pointer;
  transition: opacity .2s;
}

.alarm-row:last-of-type { margin-bottom: 0; }
.alarm-row:hover { opacity: .85; }

.alarm-icon {
  width: 36px; height: 36px;
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.alarm-icon svg {
  width: 17px; height: 17px;
  stroke: currentColor; fill: none;
  stroke-width: 1.7;
  stroke-linecap: round; stroke-linejoin: round;
}

.alarm-red    { background: var(--red-bg);    color: var(--red); }
.alarm-orange { background: var(--orange-bg); color: var(--orange); }
.alarm-gray   { background: var(--gray-bg);   color: var(--muted); }

.alarm-name { font-size: .87rem; font-weight: 700; }
.alarm-time { font-size: .75rem; color: var(--muted); margin-top: 2px; }

.alarm-arrow {
  margin-left: auto;
  color: var(--muted);
  opacity: .4;
}

.alarm-arrow svg {
  width: 14px; height: 14px;
  stroke: currentColor; fill: none;
  stroke-width: 2;
  stroke-linecap: round; stroke-linejoin: round;
}

.see-all-btn {
  display: block;
  width: 100%;
  margin-top: 14px;
  padding: 10px;
  border: 1px solid var(--border);
  border-radius: 10px;
  background: transparent;
  font-size: .82rem;
  font-weight: 700;
  font-family: 'Manrope', sans-serif;
  color: var(--coral);
  cursor: pointer;
  transition: background .2s;
}

.see-all-btn:hover { background: var(--coral-l); }

/* quick access */
.quick-desc {
  font-size: .88rem;
  color: var(--muted);
  line-height: 1.7;
  margin-bottom: 20px;
}

.map-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  text-decoration: none;
  color: #fff;
  background: var(--navy);
  padding: 13px 18px;
  border-radius: 12px;
  font-size: .88rem;
  font-weight: 700;
  box-shadow: 0 4px 14px rgba(30,48,72,.2);
  transition: all .2s;
}

.map-cta svg {
  width: 16px; height: 16px;
  stroke: #fff; fill: none;
  stroke-width: 1.8;
  stroke-linecap: round; stroke-linejoin: round;
}

.map-cta:hover { background: var(--navy-2); transform: translateY(-1px); }
</style>
</head>
