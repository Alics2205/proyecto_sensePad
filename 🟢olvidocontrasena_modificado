

<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Recuperar contraseña</title>
<style>
*{
    box-sizing:border-box;
    margin:0;
    padding:0;
    font-family:'Segoe UI',sans-serif;
}

:root{
    --bg:#faf7f4;
    --card:#ffffff;
    --border:#e9e2dc;
    --primary:#1c2b35;
    --accent:#e67e5f;
    --accent-hover:#d86c4b;
    --text:#1a1a2e;
    --muted:#8a8fa8;
}

body{
    background:var(--bg);
    color:var(--text);
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    flex-direction:column;
}

/* NAVBAR */

nav{
    width:100%;
    height:70px;
    background:var(--primary);
    display:flex;
    align-items:center;
    padding:0 35px;
    position:fixed;
    top:0;
    left:0;
    z-index:100;
    box-shadow:0 2px 8px rgba(0,0,0,.08);
}

nav a{
    text-decoration:none;
    color:white;
    font-weight:600;
    font-size:14px;
    padding:10px 18px;
    border-radius:10px;
    transition:.2s;
}

nav a:hover{
    background:rgba(255,255,255,.1);
}

/* CARD */

.main-container{
    background:var(--card);
    width:430px;
    max-width:95%;
    margin-top:100px;
    padding:35px;
    border-radius:18px;
    border:1px solid var(--border);
    box-shadow:0 10px 30px rgba(0,0,0,.08);
}

.main-container h1{
    text-align:center;
    font-size:28px;
    font-weight:700;
    color:var(--text);
    margin-bottom:25px;
}

/* INPUT */

.input-box{
    margin-bottom:18px;
}

.input-box input{
    width:100%;
    padding:14px;
    border:1px solid var(--border);
    border-radius:12px;
    font-size:14px;
    outline:none;
    transition:.2s;
    background:#fff;
}

.input-box input:focus{
    border-color:var(--accent);
    box-shadow:0 0 0 3px rgba(230,126,95,.15);
}

/* BOTON */

.submit-button{
    width:100%;
    padding:14px;
    border:none;
    border-radius:12px;
    background:var(--accent);
    color:white;
    font-size:15px;
    font-weight:600;
    cursor:pointer;
    transition:.2s;
}

.submit-button:hover{
    background:var(--accent-hover);
}

/* ERROR */

.error-message{
    text-align:center;
    margin-top:15px;
    color:#d9534f;
    font-size:14px;
}

/* RESPONSIVE */

@media(max-width:768px){

    nav{
        justify-content:center;
    }

    .main-container{
        width:90%;
        padding:28px;
    }

    .main-container h1{
        font-size:24px;
    }
}
</style>
</head>
<body>
	<nav>
		<a href="/Sensebagpack/vistas/index.jsp">Inicio</a>
	</nav>

	<div class="main-container">
		<h1>Recuperar contraseña</h1>
		<form action="/Sensebagpack/Leer" method="post">
			<div class="input-box">
				<input type="text" name="dni" placeholder="Ingrese su Dni:" required />
			</div>
			<button type="submit" class="submit-button">Verificar DNI</button>
		</form>

	</div>
</body>
</html>
