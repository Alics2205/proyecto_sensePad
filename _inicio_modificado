

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SenseBagPack</title>

<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:"Manrope",sans-serif;
}

body{
    background:#f7f4f1;
    color:#1f2937;
    line-height:1.7;
}

/* HEADER */

header{
    background:#1e3048;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:1.2rem 3rem;
    box-shadow:0 4px 15px rgba(0,0,0,.08);
    position:sticky;
    top:0;
    z-index:1000;
}

.logo-container{
    display:flex;
    align-items:center;
    gap:15px;
}

.logo-container img{
    height:70px;
    width:auto;
    transition:.3s;
}

.logo-container img:hover{
    transform:scale(1.05);
}

.logo-text{
    font-size:2rem;
    font-weight:800;
    color:#ffffff;
    letter-spacing:.5px;
}

/* MENÚ */

.menu-container{
    position:relative;
}

.menu-btn{
    font-size:28px;
    color:white;
    cursor:pointer;
    transition:.25s;
}

.menu-btn:hover{
    transform:scale(1.1);
}

.menu{
    display:none;
    position:absolute;
    right:0;
    top:50px;
    background:white;
    border-radius:14px;
    width:220px;
    overflow:hidden;
    box-shadow:0 10px 30px rgba(0,0,0,.15);
}

.menu a{
    display:block;
    padding:14px;
    text-decoration:none;
    color:#374151;
    font-weight:600;
    transition:.25s;
}

.menu a:hover{
    background:#f4f4f4;
    color:#e07a5f;
}

/* CONTENIDO */

section{
    max-width:1100px;
    margin:60px auto;
    background:white;
    padding:70px 50px;
    border-radius:24px;
    border:1px solid #ebe5df;
    box-shadow:0 4px 15px rgba(0,0,0,.04);
    text-align:center;
}

h2{
    font-size:2.5rem;
    font-weight:800;
    color:#1f2937;
    margin-bottom:20px;
}

p{
    max-width:800px;
    margin:auto;
    font-size:1.08rem;
    color:#6b7280;
    font-weight:400;
}

/* BOTÓN */

.btn{
    display:inline-block;
    margin-top:30px;
    background:#e07a5f;
    color:white;
    padding:14px 28px;
    border-radius:12px;
    text-decoration:none;
    font-weight:700;
    transition:.25s;
    box-shadow:0 4px 12px rgba(224,122,95,.25);
}

.btn:hover{
    background:#cf6b51;
    transform:translateY(-2px);
}

/* FOOTER */

footer{
    margin-top:50px;
    background:#1e3048;
    color:white;
    text-align:center;
    padding:20px;
    font-size:.95rem;
    letter-spacing:.5px;
}
</style>
</head>

<body>

<header>
  <div class="logo-container">
    <span class="logo-text">SenseBagPack</span>
  
    <img src="/Sensebagpack/imagenes/loguito.png" alt="Logo del sistema" />
  
</div>
  <div class="menu-container">
    <div class="menu-btn" onclick="toggleMenu()">☰</div>

    <div id="menu" class="menu">
      <a href="/Sensebagpack/vistas/usuario.jsp">Acceder</a>
      <a href="/Sensebagpack/vistas/elegirnos.jsp">¿Por qué elegirnos?</a>
      <a href="/Sensebagpack/vistas/contacto.jsp">Contacto</a>
       <a href="/Sensebagpack/vistas/contacto.jsp">Objetivo</a>
    </div>
  </div>
</header>

<section>
  <h2>Bienvenido a SenseBagPack</h2>
  <p>
    Un proyecto innovador que busca mejorar la movilidad y seguridad de las personas no videntes.  
    Combinamos tecnología, empatía y diseño inteligente en una mochila que detecta obstáculos y mantiene a las familias conectadas.
  </p>
  <a href="#" class="btn">Conocer más</a>
</section>




<footer>
  © 2025 SenseBagPack — Innovación con propósito.
</footer>

<script>
function toggleMenu() {
  const menu = document.getElementById("menu");
  menu.style.display = (menu.style.display === "block") ? "none" : "block";
}

window.onclick = function(event) {
  if (!event.target.matches('.menu-btn')) {
    const menu = document.getElementById("menu");
    if (menu.style.display === "block") {
      menu.style.display = "none";
    }
  }
}

</script>

</body>
</html>
