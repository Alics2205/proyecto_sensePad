<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SenseBagPack — Mapa en tiempo real</title>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=DM+Serif+Display&display=swap" rel="stylesheet" />

  <style>
    /* ─────────────────────────────────────────
       RESET
    ───────────────────────────────────────── */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    html { font-size: 16px; scroll-behavior: smooth; }
    ul { list-style: none; }
    a { text-decoration: none; color: inherit; }
    button { cursor: pointer; border: none; background: none; font-family: inherit; }
    svg { display: block; }

    /* ─────────────────────────────────────────
       VARIABLES
    ───────────────────────────────────────── */
    :root {
      --bg: #faf5f0;
      --navy: #1e3048;
      --coral: #c4715a;
      --coral-dim: rgba(196, 113, 90, .11);
      --white: #ffffff;
      --border: #e4dbd2;
      --text: #1a1f2e;
      --muted: #9a8c84;
      --green: #3a9e6f;
      --green-dim: rgba(58, 158, 111, .13);
      --amber: #e8920a;
      --amber-dim: rgba(232, 146, 10, .12);
      --blue: #3b6fcf;
      --blue-dim: rgba(59, 111, 207, .11);
      --sidebar-w: 228px;
      --navbar-h: 60px;
      --radius: 14px;
      --shadow: 0 2px 16px rgba(30, 48, 72, .08);
      --shadow-lg: 0 6px 32px rgba(30, 48, 72, .12);
      --font-body: 'Manrope', sans-serif;
      --font-display: 'DM Serif Display', serif;
      --transition: 0.18s ease;
    }

    /* ─────────────────────────────────────────
       BODY
    ───────────────────────────────────────── */
    body {
      font-family: var(--font-body);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ─────────────────────────────────────────
       NAVBAR
    ───────────────────────────────────────── */
    .navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: var(--navbar-h);
      background: var(--navy);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 24px;
      z-index: 100;
      box-shadow: 0 2px 12px rgba(0,0,0,.18);
    }

    .navbar__brand {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .navbar__logo-icon {
      width: 32px; height: 32px;
      background: var(--coral);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
    }

    .navbar__logo-icon svg {
      width: 18px; height: 18px;
      fill: #fff;
    }

    .navbar__brand-name {
      font-family: var(--font-display);
      font-size: 1.15rem;
      color: #fff;
      letter-spacing: 0.01em;
    }

    .navbar__actions {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .navbar__notif {
      position: relative;
      width: 38px; height: 38px;
      border-radius: 50%;
      background: rgba(255,255,255,.08);
      display: flex; align-items: center; justify-content: center;
      transition: background var(--transition);
    }
    .navbar__notif:hover { background: rgba(255,255,255,.16); }
    .navbar__notif svg { width: 20px; height: 20px; stroke: #fff; fill: none; }
    .navbar__notif-badge {
      position: absolute;
      top: 4px; right: 4px;
      width: 16px; height: 16px;
      background: var(--coral);
      border-radius: 50%;
      border: 2px solid var(--navy);
      font-size: 9px;
      font-weight: 700;
      color: #fff;
      display: flex; align-items: center; justify-content: center;
    }

    .navbar__user {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 4px 12px 4px 4px;
      border-radius: 30px;
      background: rgba(255,255,255,.08);
      transition: background var(--transition);
      cursor: pointer;
    }
    .navbar__user:hover { background: rgba(255,255,255,.14); }
    .navbar__avatar {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: linear-gradient(135deg, #c4715a 0%, #8a4f3a 100%);
      display: flex; align-items: center; justify-content: center;
      font-size: 13px;
      font-weight: 700;
      color: #fff;
    }
    .navbar__username {
      font-size: 0.82rem;
      font-weight: 600;
      color: #fff;
    }
    .navbar__chevron {
      width: 14px; height: 14px;
      stroke: rgba(255,255,255,.6);
      fill: none;
    }

    /* User dropdown */
    .navbar__dropdown-wrap {
      position: relative;
    }
    .navbar__dropdown {
      display: none;
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-lg);
      min-width: 170px;
      overflow: hidden;
      z-index: 200;
    }
    .navbar__dropdown-wrap:hover .navbar__dropdown,
    .navbar__dropdown-wrap:focus-within .navbar__dropdown {
      display: block;
    }
    .navbar__dropdown li a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 11px 18px;
      font-size: 0.84rem;
      font-weight: 500;
      color: var(--text);
      transition: background var(--transition);
    }
    .navbar__dropdown li a:hover { background: var(--bg); }
    .navbar__dropdown li a svg {
      width: 15px; height: 15px;
      stroke: var(--muted);
      fill: none;
    }
    .navbar__dropdown li:last-child a { color: var(--coral); }
    .navbar__dropdown li:last-child a svg { stroke: var(--coral); }
    .navbar__dropdown .dropdown-divider {
      height: 1px;
      background: var(--border);
      margin: 4px 0;
    }

    /* ─────────────────────────────────────────
       SIDEBAR
    ───────────────────────────────────────── */
    .layout {
      display: flex;
      margin-top: var(--navbar-h);
      min-height: calc(100vh - var(--navbar-h));
    }

    .sidebar {
      position: fixed;
      top: var(--navbar-h);
      left: 0;
      bottom: 0;
      width: var(--sidebar-w);
      background: var(--white);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 20px 0;
      overflow-y: auto;
      z-index: 90;
    }

    .sidebar__nav { flex: 1; }

    .sidebar__item {
      display: flex;
      align-items: center;
      gap: 11px;
      padding: 11px 20px;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--muted);
      border-radius: 0;
      cursor: pointer;
      transition: color var(--transition), background var(--transition);
      position: relative;
    }
    .sidebar__item svg {
      width: 18px; height: 18px;
      stroke: currentColor;
      fill: none;
      flex-shrink: 0;
    }
    .sidebar__item:hover {
      color: var(--text);
      background: var(--bg);
    }
    .sidebar__item--active {
      color: var(--coral);
      background: var(--coral-dim);
      font-weight: 600;
    }
    .sidebar__item--active::before {
      content: '';
      position: absolute;
      left: 0; top: 50%;
      transform: translateY(-50%);
      width: 3px; height: 60%;
      background: var(--coral);
      border-radius: 0 3px 3px 0;
    }
    .sidebar__item--active svg { stroke: var(--coral); }

    .sidebar__divider {
      height: 1px;
      background: var(--border);
      margin: 10px 16px;
    }

    /* Device status card inside sidebar */
    .sidebar__device {
      margin: 0 12px 4px;
      background: var(--navy);
      border-radius: var(--radius);
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .sidebar__device-icon {
      width: 40px; height: 40px;
      background: rgba(255,255,255,.1);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .sidebar__device-icon svg {
      width: 22px; height: 22px;
      stroke: #fff;
      fill: none;
    }
    .sidebar__device-label {
      font-size: 0.7rem;
      color: rgba(255,255,255,.5);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 2px;
    }
    .sidebar__device-name {
      font-size: 0.85rem;
      font-weight: 700;
      color: #fff;
    }
    .sidebar__device-status {
      display: flex;
      align-items: center;
      gap: 5px;
      margin-top: 4px;
    }
    .sidebar__device-dot {
      width: 7px; height: 7px;
      background: #4ade80;
      border-radius: 50%;
      animation: pulse-dot 2s infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
    .sidebar__device-connected {
      font-size: 0.76rem;
      color: #4ade80;
      font-weight: 600;
    }

    /* ─────────────────────────────────────────
       MAIN CONTENT
    ───────────────────────────────────────── */
    .main {
      margin-left: var(--sidebar-w);
      flex: 1;
      padding: 32px 28px;
      display: flex;
      flex-direction: column;
      gap: 24px;
      max-width: 100%;
    }

    .page-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .page-header__titles { }
    .page-header__title {
      font-family: var(--font-display);
      font-size: 1.85rem;
      color: var(--text);
      line-height: 1.15;
    }
    .page-header__subtitle {
      font-size: 0.84rem;
      color: var(--muted);
      margin-top: 4px;
    }
    .page-header__actions {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 4px;
    }
    .page-header__update-info {
      font-size: 0.75rem;
      color: var(--muted);
    }

    .content-grid {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 20px;
      align-items: start;
    }

    .left-column {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .right-column {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    /* ─────────────────────────────────────────
       MAP CARD
    ───────────────────────────────────────── */
    .map-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
    }

    .map-container {
      position: relative;
      width: 100%;
      height: 380px;
      background: #e8e0d6;
      overflow: hidden;
    }

    /* SVG map background grid lines */
    .map-bg {
      position: absolute;
      inset: 0;
      width: 100%; height: 100%;
    }

    .map-controls {
      position: absolute;
      top: 14px; left: 14px;
      display: flex;
      flex-direction: column;
      gap: 2px;
      z-index: 10;
    }
    .map-controls button {
      width: 32px; height: 32px;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 6px;
      font-size: 18px;
      font-weight: 300;
      color: var(--text);
      display: flex; align-items: center; justify-content: center;
      box-shadow: var(--shadow);
      transition: background var(--transition);
    }
    .map-controls button:hover { background: var(--bg); }

    .map-locate-btn {
      position: absolute;
      top: 14px; right: 14px;
      width: 36px; height: 36px;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      box-shadow: var(--shadow);
      z-index: 10;
      cursor: pointer;
      transition: background var(--transition);
    }
    .map-locate-btn:hover { background: var(--bg); }
    .map-locate-btn svg { width: 18px; height: 18px; stroke: var(--navy); fill: none; }

    /* Map tooltips */
    .map-tooltip {
      position: absolute;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px 14px;
      box-shadow: var(--shadow-lg);
      font-size: 0.8rem;
      z-index: 10;
      pointer-events: none;
    }
    .map-tooltip__label {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
      margin-bottom: 2px;
    }
    .map-tooltip__value {
      font-size: 0.88rem;
      font-weight: 700;
      color: var(--text);
    }
    .map-tooltip__time {
      font-size: 0.75rem;
      color: var(--muted);
      margin-top: 2px;
    }

    .map-tooltip--origin {
      top: 26%; left: 10%;
    }
    .map-tooltip--current {
      top: 22%; right: 10%;
    }

    /* Map footer */
    .map-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 18px;
      border-top: 1px solid var(--border);
      flex-wrap: wrap;
      gap: 10px;
    }
    .map-legend {
      display: flex;
      align-items: center;
      gap: 18px;
      flex-wrap: wrap;
    }
    .map-legend__item {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 0.78rem;
      color: var(--muted);
      font-weight: 500;
    }
    .legend-line {
      width: 28px; height: 3px;
      border-radius: 2px;
    }
    .legend-line--green { background: var(--green); }
    .legend-line--gray {
      background: repeating-linear-gradient(90deg, #bbb 0, #bbb 5px, transparent 5px, transparent 9px);
      height: 2px;
    }
    .legend-line--orange {
      background: repeating-linear-gradient(90deg, var(--amber) 0, var(--amber) 6px, transparent 6px, transparent 10px);
    }

    .map-precision {
      font-size: 0.76rem;
      color: var(--muted);
    }

    /* Trip details strip */
    .trip-timeline {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 22px 24px;
      box-shadow: var(--shadow);
    }
    .trip-timeline__title {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 20px;
    }
    .timeline-track {
      position: relative;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
    }
    .timeline-track::before {
      content: '';
      position: absolute;
      top: 18px;
      left: 20px; right: 20px;
      height: 3px;
      background: var(--border);
      z-index: 0;
    }
    .timeline-track__segment {
      position: absolute;
      top: 18px;
      left: 20px;
      height: 3px;
      width: 50%;
      background: var(--green);
      z-index: 1;
    }
    .timeline-track__segment-deviation {
      position: absolute;
      top: 18px;
      left: 70%;
      height: 3px;
      width: 13%;
      background: repeating-linear-gradient(90deg, var(--amber) 0, var(--amber) 5px, transparent 5px, transparent 9px);
      z-index: 2;
    }
    .timeline-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      position: relative;
      z-index: 3;
      flex: 1;
    }
    .timeline-step__icon {
      width: 38px; height: 38px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      border: 2px solid var(--border);
      background: var(--white);
    }
    .timeline-step__icon svg {
      width: 18px; height: 18px;
      stroke-width: 1.8;
      fill: none;
    }
    .timeline-step__icon--origin { border-color: var(--green); background: var(--green-dim); }
    .timeline-step__icon--origin svg { stroke: var(--green); }
    .timeline-step__icon--walking { border-color: var(--green); background: var(--green-dim); }
    .timeline-step__icon--walking svg { stroke: var(--green); }
    .timeline-step__icon--deviation { border-color: var(--amber); background: var(--amber-dim); }
    .timeline-step__icon--deviation svg { stroke: var(--amber); }
    .timeline-step__icon--location { border-color: var(--coral); background: var(--coral-dim); }
    .timeline-step__icon--location svg { stroke: var(--coral); }
    .timeline-step__label {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--text);
      text-align: center;
      line-height: 1.3;
    }
    .timeline-step__sub {
      font-size: 0.72rem;
      color: var(--muted);
      text-align: center;
      margin-top: -6px;
    }

    /* ─────────────────────────────────────────
       INFO PANEL
    ───────────────────────────────────────── */
    .info-panel {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
    }
    .info-panel__header {
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .info-panel__header-icon {
      width: 30px; height: 30px;
      background: var(--coral-dim);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
    }
    .info-panel__header-icon svg {
      width: 16px; height: 16px;
      stroke: var(--coral);
      fill: none;
    }
    .info-panel__header h3 {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--text);
    }

    .info-item {
      padding: 14px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }
    .info-item:last-child { border-bottom: none; }
    .info-item__icon {
      width: 34px; height: 34px;
      border-radius: 9px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .info-item__icon svg {
      width: 17px; height: 17px;
      fill: none;
      stroke-width: 1.8;
    }
    .info-item__icon--green { background: var(--green-dim); }
    .info-item__icon--green svg { stroke: var(--green); }
    .info-item__icon--amber { background: var(--amber-dim); }
    .info-item__icon--amber svg { stroke: var(--amber); }
    .info-item__icon--coral { background: var(--coral-dim); }
    .info-item__icon--coral svg { stroke: var(--coral); }
    .info-item__icon--blue { background: var(--blue-dim); }
    .info-item__icon--blue svg { stroke: var(--blue); }
    .info-item__icon--navy { background: rgba(30,48,72,.09); }
    .info-item__icon--navy svg { stroke: var(--navy); }

    .info-item__body { flex: 1; min-width: 0; }
    .info-item__label {
      font-size: 0.72rem;
      color: var(--muted);
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 3px;
    }
    .info-item__value {
      font-size: 1.15rem;
      font-weight: 800;
      color: var(--text);
      line-height: 1.2;
    }
    .info-item__sub {
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 2px;
    }
    .info-item__tag {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 700;
      margin-top: 3px;
      padding: 2px 8px;
      border-radius: 20px;
    }
    .info-item__tag--red { background: rgba(196,113,90,.14); color: var(--coral); }
    .info-item__tag--green { background: var(--green-dim); color: var(--green); }

    /* ─────────────────────────────────────────
       ROUTES PANEL
    ───────────────────────────────────────── */
    .routes-panel {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
    }
    .routes-panel__header {
      padding: 16px 20px 12px;
      border-bottom: 1px solid var(--border);
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--text);
    }

    .route-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 13px 20px;
      border-bottom: 1px solid var(--border);
      cursor: pointer;
      transition: background var(--transition);
    }
    .route-item:last-of-type { border-bottom: none; }
    .route-item:hover { background: var(--bg); }
    .route-item--active { background: #fff8f6; }

    .route-item__num {
      width: 28px; height: 28px;
      border-radius: 50%;
      font-size: 0.8rem;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .route-item--active .route-item__num {
      background: var(--coral);
      color: #fff;
    }
    .route-item:not(.route-item--active) .route-item__num {
      background: var(--bg);
      color: var(--muted);
      border: 1px solid var(--border);
    }
    .route-item__info { flex: 1; min-width: 0; }
    .route-item__name {
      font-size: 0.84rem;
      font-weight: 600;
      color: var(--text);
    }
    .route-item__meta {
      display: flex;
      gap: 10px;
      margin-top: 2px;
    }
    .route-item__meta span {
      font-size: 0.74rem;
      color: var(--muted);
    }
    .route-item__check svg {
      width: 16px; height: 16px;
      stroke: var(--coral);
      fill: none;
      stroke-width: 2.5;
    }

    .routes-panel__action {
      padding: 12px 20px;
      border-top: 1px solid var(--border);
    }

    /* ─────────────────────────────────────────
       DEVICE STATUS
    ───────────────────────────────────────── */
    /* Handled inside sidebar — see .sidebar__device */

    /* ─────────────────────────────────────────
       BUTTONS
    ───────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 9px 18px;
      border-radius: 10px;
      font-family: var(--font-body);
      font-size: 0.82rem;
      font-weight: 600;
      transition: all var(--transition);
      cursor: pointer;
      border: none;
    }
    .btn svg {
      width: 15px; height: 15px;
      stroke: currentColor;
      fill: none;
      stroke-width: 2;
    }

    .btn--outline {
