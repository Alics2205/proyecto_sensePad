  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
 
    :root {
      --navy:     #1e3048;
      --navy-mid: #253d58;
      --coral:    #c4715a;
      --coral-hi: #d4856e;
      --cream:    #faf5f0;
      --sand:     #f0e8e0;
      --text:     #1a1f2e;
      --text-mid: #4a4540;
      --muted:    #8a8078;
      --white:    #ffffff;
      --border:   #e4dbd2;
    }
 
    html { scroll-behavior: smooth; }
 
    body {
      background: var(--cream);
      color: var(--text);
      font-family: 'Manrope', sans-serif;
      line-height: 1.7;
      overflow-x: hidden;
    }
 
    /* ─── HEADER ─── */
    header {
      background: var(--navy);
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 3.5rem;
      height: 72px;
      position: sticky;
      top: 0;
      z-index: 1000;
      box-shadow: 0 2px 24px rgba(0,0,0,.18);
    }
 
    /* thin coral accent line at bottom of header */
    header::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--coral), transparent);
      opacity: .6;
    }
 
    .logo-container {
      display: flex;
      align-items: center;
      gap: 14px;
    }
 
    .logo-container img {
      height: 52px;
      width: auto;
      border-radius: 10px;
      background: rgba(255,255,255,0.07);
      padding: 3px;
      transition: transform .3s;
    }
 
    .logo-container img:hover { transform: scale(1.06); }
 
    .logo-text {
      font-family: 'DM Serif Display', serif;
      font-size: 1.45rem;
      color: var(--white);
      letter-spacing: .3px;
      line-height: 1;
    }
 
    .logo-text span {
      display: block;
      font-family: 'Manrope', sans-serif;
      font-size: .65rem;
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: rgba(255,255,255,.38);
      margin-top: 3px;
    }
 
    /* ─── MENU ─── */
    .menu-container { position: relative; }
 
    .menu-btn {
      width: 40px; height: 40px;
      display: flex; flex-direction: column;
      justify-content: center; align-items: center;
      gap: 5px;
      cursor: pointer;
      border-radius: 10px;
      transition: background .2s;
      padding: 8px;
    }
 
    .menu-btn:hover { background: rgba(255,255,255,.1); }
 
    .menu-btn .bar {
      width: 22px; height: 2px;
      background: rgba(255,255,255,.85);
      border-radius: 2px;
      transition: all .25s;
    }
 
    .menu-btn .bar:nth-child(2) { width: 16px; align-self: flex-end; }
 
    .menu {
      display: none;
      position: absolute;
      right: 0; top: calc(100% + 10px);
      background: var(--white);
      border-radius: 16px;
      width: 220px;
      overflow: hidden;
      box-shadow: 0 16px 48px rgba(0,0,0,.14);
      border: 1px solid var(--border);
    }
 
    /* small arrow pointer */
    .menu::before {
      content: '';
      position: absolute;
      top: -6px; right: 14px;
      width: 12px; height: 12px;
      background: var(--white);
      border-left: 1px solid var(--border);
      border-top: 1px solid var(--border);
      transform: rotate(45deg);
    }
 
    .menu a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 13px 18px;
      text-decoration: none;
      color: var(--text-mid);
      font-weight: 600;
      font-size: .9rem;
      transition: all .2s;
      border-bottom: 1px solid #f5f0eb;
    }
 
    .menu a:last-child { border-bottom: none; }
 
    .menu a .dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--border);
      flex-shrink: 0;
      transition: background .2s;
    }
 
    .menu a:hover {
      background: #fdf4ef;
      color: var(--coral);
      padding-left: 22px;
    }
 
    .menu a:hover .dot { background: var(--coral); }
 
    /* ─── HERO SECTION ─── */
    section {
      max-width: 1080px;
      margin: 70px auto;
      padding: 0 24px;
      text-align: center;
    }
 
    /* decorative card wrapping content */
    .hero-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 28px;
      padding: 80px 60px 70px;
      box-shadow: 0 8px 40px rgba(0,0,0,.05);
      position: relative;
      overflow: hidden;
    }
 
    /* soft background blob */
    .hero-card::before {
      content: '';
      position: absolute;
      top: -80px; right: -80px;
      width: 320px; height: 320px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(196,113,90,.10) 0%, transparent 70%);
      pointer-events: none;
    }
 
    .hero-card::after {
      content: '';
      position: absolute;
      bottom: -60px; left: -60px;
      width: 260px; height: 260px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(30,48,72,.07) 0%, transparent 70%);
      pointer-events: none;
    }
 
    /* eyebrow label */
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(196,113,90,.1);
      color: var(--coral);
      font-size: .75rem;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 6px 14px;
      border-radius: 20px;
      margin-bottom: 24px;
      border: 1px solid rgba(196,113,90,.2);
    }
 
    .eyebrow-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--coral);
      animation: blink 2s ease-in-out infinite;
    }
 
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.2} }
 
    h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 3rem;
      font-weight: 400;
      color: var(--text);
      line-height: 1.2;
      margin-bottom: 22px;
      letter-spacing: -.3px;
    }
 
    h2 em {
      font-style: italic;
      color: var(--coral);
    }
 
    p {
      max-width: 620px;
      margin: 0 auto;
      font-size: 1.05rem;
      color: var(--muted);
      font-weight: 400;
      line-height: 1.8;
    }
 
    /* ─── CTA BUTTON ─── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      margin-top: 38px;
      background: var(--coral);
      color: white;
      padding: 15px 30px;
      border-radius: 14px;
      text-decoration: none;
      font-weight: 700;
      font-size: .95rem;
      transition: all .25s;
      box-shadow: 0 6px 20px rgba(196,113,90,.3);
      letter-spacing: .2px;
    }
 
    .btn-arrow {
      width: 18px; height: 18px;
      border-radius: 50%;
      background: rgba(255,255,255,.25);
      display: flex; align-items: center; justify-content: center;
      font-size: .8rem;
      transition: transform .25s;
    }
 
    .btn:hover {
      background: #b5624c;
      transform: translateY(-3px);
      box-shadow: 0 10px 28px rgba(196,113,90,.38);
    }
 
    .btn:hover .btn-arrow { transform: translateX(3px); }
 
    /* ─── FEATURE PILLS ─── */
    .pills {
      display: flex;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 40px;
      padding-top: 36px;
      border-top: 1px solid var(--border);
    }
 
    .pill {
      display: flex;
      align-items: center;
      gap: 7px;
      background: var(--cream);
      border: 1px solid var(--border);
      color: var(--text-mid);
      font-size: .82rem;
      font-weight: 600;
      padding: 8px 16px;
      border-radius: 20px;
    }
 
    .pill-icon {
      font-size: .85rem;
    }
 
    /* ─── FOOTER ─── */
    footer {
      background: var(--navy);
      color: rgba(255,255,255,.45);
      text-align: center;
      padding: 22px;
      font-size: .85rem;
      letter-spacing: .8px;
      font-weight: 500;
    }
 
    footer strong {
      color: rgba(255,255,255,.75);
      font-weight: 700;
    }
  </style>
</head>
 
